# Copy this file to `.env` and fill in values. NEVER commit `.env` (it is gitignored).

# Kaggle API credentials. NOT needed for V1 — the V1 spine (martj42 international
# results) downloads from GitHub raw without credentials. These are only for the
# V1.1 FIFA men's ranking dataset (hosted on Kaggle).
# Get them from https://www.kaggle.com/settings -> "Create New Token".
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional: override the default data directory (defaults to ./data).
# WORLDCUP_DATA_DIR=
